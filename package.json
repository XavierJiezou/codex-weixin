{
  "name": "codex-weixin",
  "version": "0.1.0",
  "description": "Independent WeChat bridge for local OpenAI Codex sessions.",
  "license": "MIT",
  "author": "Xuechao Zou",
  "type": "module",
  "bin": {
    "codex-weixin": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx test/*.test.ts",
    "prepack": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
